{% extends "basefront.html.twig" %}

{% block body %}
    <table class="table table-striped">
        <thead>
            <tr>
                <th class="text_left" scope="col">
                    Ville
                    <!-- Tri Ville ASC -->
                    <a href="{{ path('voyages.sort', { champ: 'ville', ordre: 'ASC' }) }}">▲</a>
                    <!-- Tri Ville DESC -->
                    <a href="{{ path('voyages.sort', { champ: 'ville', ordre: 'DESC' }) }}">▼</a>
                </th>

                <th class="text-left" scope="col">Pays</th>

                <th class="text-end" scope="col">Note</th>

                <th class="text-center" scope="col">
                    Date
                    <!-- Tri Date ASC -->
                    <a href="{{ path('voyages.sort', { champ: 'datecreation', ordre: 'ASC' }) }}">▲</a>
                    <!-- Tri Date DESC -->
                    <a href="{{ path('voyages.sort', { champ: 'datecreation', ordre: 'DESC' }) }}">▼</a>
                </th>
            </tr>
        </thead>

        <tbody>
            {% for visite in visites %}
                <tr>
                    <td>
                        <h5 class="text-primary">
                            <a href="#">{{ visite.ville }}</a>
                        </h5>
                    </td>

                    <td>{{ visite.pays }}</td>

                    <td class="text-end">
                        {% if visite.note < 10 %}
                            <div class="text-danger">{{ visite.note }}/20</div>
                        {% else %}
                            <div class="text-success">{{ visite.note }}/20</div>
                        {% endif %}
                    </td>

                    <td class="text-center">
                        {{ visite.datecreationstring }}
                    </td>
                </tr>
            {% endfor %}
        </tbody>
    </table>
{% endblock %}
