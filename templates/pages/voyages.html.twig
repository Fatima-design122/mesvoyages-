{% extends "basefront.html.twig" %}

{% block body %}

    <h2 class="mb-4">Liste des voyages</h2>

    <table class="table table-striped">
        <thead>
            <tr>
                <!-- Colonne Ville -->
                <th class="text-left align-top" scope="col">
                    Ville
                    <a href="{{ path('voyages.sort', { champ:'ville', ordre:'ASC' }) }}">▲</a>
                    <a href="{{ path('voyages.sort', { champ:'ville', ordre:'DESC' }) }}">▼</a>

                    <!-- Formulaire de filtre pour la VILLE -->
                    <form class="form-inline mt-1" method="POST" action="{{ path('voyages.findallequal', { champ:'ville' }) }}">
                        <div class="form-group ml-1 mb-2">
                            <input type="text" class="sm" name="recherche" placeholder="Rechercher une ville">
                        </div>
                        <button type="submit" class="btn btn-primary btn-sm mb-2 ml-1">Filtrer</button>
                    </form>
                </th>

                <!-- Colonne Pays (sans filtre) -->
                <th class="text-left align-top" scope="col">Pays</th>

                <!-- Colonne Note -->
                <th class="text-end align-top" scope="col">Note</th>

                <!-- Colonne Date -->
                <th class="text-center align-top" scope="col">
                    Date
                    <a href="{{ path('voyages.sort', { champ:'datecreation', ordre:'ASC' }) }}">▲</a>
                    <a href="{{ path('voyages.sort', { champ:'datecreation', ordre:'DESC' }) }}">▼</a>
                </th>
            </tr>
        </thead>

        <tbody>
            {% for visite in visites %}
                <tr>
                    <td>
                        <h5 class="text-primary mb-0">{{ visite.ville }}</h5>
                    </td>

                    <td>{{ visite.pays }}</td>

                    <td class="text-end">
                        {% if visite.note < 10 %}
                            <span class="text-danger">{{ visite.note }}/20</span>
                        {% else %}
                            <span class="text-success">{{ visite.note }}/20</span>
                        {% endif %}
                    </td>

                    <td class="text-center">
                        {{ visite.datecreationstring }}
                    </td>
                </tr>
            {% endfor %}
        </tbody>
    </table>

{% endblock %}
